generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  phone        String?
  passwordHash String
  role         String       @default("USER")
  status       String       @default("ACTIVE")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  bookmarks       Bookmark[]
  itineraries     Itinerary[]
  notifications   Notification[]
  recommendations Recommendation[]
  reviews         Review[]
  suggestions     DestinationSuggestion[]
}

model Category {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  destinations Destination[]
}

model Destination {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  description     String
  location        String
  mapLink         String?
  latitude        Float?
  longitude       Float?
  imageUrls       String     @default("[]")
  estimatedBudget Int
  bestTimeToVisit String
  duration        String
  difficulty      String
  localFood       String     @default("[]")
  nearbyAttractions String   @default("[]")
  transportation  String
  safetyTips      String     @default("[]")
  averageRating   Float      @default(0)
  reviewCount     Int        @default(0)
  isFeatured      Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  bookmarks       Bookmark[]
  itineraries     Itinerary[]
  recommendations Recommendation[]
  reviews         Review[]

  @@index([categoryId])
  @@index([difficulty])
  @@index([location])
}

model Review {
  id                 String       @id @default(cuid())
  rating             Int
  remark             String
  difficultyFeedback String?
  status             String       @default("PENDING")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  destinationId String
  userId        String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, destinationId])
  @@index([destinationId])
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  destinationId String
  userId        String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, destinationId])
}

model Itinerary {
  id          String     @id @default(cuid())
  title       String
  duration    String
  budget      Int
  travelStyle String
  difficulty  String
  planJson    String
  budgetJson  String
  summary     String
  aiProvider  String     @default("fallback")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  destinationId String
  userId        String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([destinationId])
}

model Recommendation {
  id              String   @id @default(cuid())
  preferencesJson String
  reason          String
  createdAt       DateTime @default(now())

  destinationId String
  userId        String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DestinationSuggestion {
  id              String           @id @default(cuid())
  name            String
  categoryName    String
  location        String
  description     String
  estimatedBudget Int?
  bestTimeToVisit String?
  difficulty      String?
  status          String           @default("PENDING")
  adminNote       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model ReportSnapshot {
  id        String     @id @default(cuid())
  type      String
  dataJson  String
  createdAt DateTime   @default(now())
}
